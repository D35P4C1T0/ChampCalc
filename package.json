{
  "name": "champions-ev-calculator",
  "version": "0.1.0",
  "private": true,
  "license": "GPL-3.0-only",
  "type": "module",
  "description": "Mobile-first EV calculator with Showdown set parsing",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "tsx watch src/local-server.ts",
