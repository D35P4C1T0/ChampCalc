    "start": "node dist/local-server.js",
    "check": "tsc --project tsconfig.test.json",
    "test": "node --import tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "fastify": "^5.8.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "playwright": "^1.59.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vercel": "^50.39.0"
  }
}
